              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "let res=pm.response.json(); \r",
                  "// will convert raw string to json-->json parsing\r",
                  "\r",
                  "let shopperId=res.data.userId;\r",
                  "pm.environment.set(\"shopperId\", shopperId);\r",
                  "\r",
                  "let email=res.data.email;\r",
                  "pm.environment.set(\"shopperEmail\", email);\r",
                  "\r",
                  "pm.environment.set(\"shopperPwd\", \"secret@123\"); //as there is no password response in the data"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
